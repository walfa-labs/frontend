# Base URL of the backend API. In production, same-origin via Caddy reverse proxy.
NUXT_PUBLIC_API_BASE=/api/v1

# Canonical site URL — used for Open Graph tags and canonical links.
NUXT_PUBLIC_SITE_URL=https://portfolio.example.com

# Site display name (used in <title> and header).
NUXT_PUBLIC_SITE_NAME=Portfolio
